          "generated": [
            "/workspace/data/news/analysis/news_llm_{region}_{YYYYMMDD}.json"
          ]
        },
        {
          "script": "/workspace/scripts/news/build_payload.py",
          "calls": [
            "run_build_source_news(news_analysis_path)",
            "collect_news_data_package(llm_output, news_meta, client, rules_config, collection_region)",
            "collect_region_transactions(...)",
            "_extract_subject_apartments(...)",
            "_extract_peer_apartments(...)",
            "_build_area_stats(...)",
            "_run_signal_detection(...)",
            "_prepare_writer_signals(...)"
